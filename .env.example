# Copia esse arquivo pra .env e ajusta os valores

# ── App
PORT=3005
NODE_ENV=development
JWT_SECRET=mude-isso-em-producao-use-uma-string-aleatoria-longa
APP_URL=http://localhost:5173

# ── Email (deixe SMTP_HOST vazio se quiser desabilitar emails)
# Exemplo Gmail (com senha de app):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=seu@gmail.com
#   SMTP_PASS=app-password-de-16-chars
#
# Exemplo Resend (recomendado pra produção, gratuito até 3k/mês):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

MAIL_FROM=Oxi Pedidos <pedidos@oxiquimicavarginha.com.br>
ADMIN_NOTIFY_EMAIL=admin@oxiquimicavarginha.com.br
